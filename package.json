{
  "name": "clipsync",
  "version": "1.0.0",
  "description": "局域网跨设备剪贴板同步工具 — Windows/iPadOS/HarmonyOS",
  "main": "src/main/main.js",
  "scripts": {
    "start": "node src/server/index.js",
    "dev": "node src/server/index.js --dev",
    "electron": "unset ELECTRON_RUN_AS_NODE && electron .",
    "build": "electron-builder"
  },
  "author": "",
  "license": "MIT",
  "dependencies": {
    "better-sqlite3": "^9.6.0",
    "bonjour": "^3.5.0",
    "express": "^4.18.2",
    "multer": "^2.1.1",
    "qrcode": "^1.5.4",
    "uuid": "^9.0.0",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "electron": "^28.3.3",
    "electron-builder": "^24.9.0"
  },
  "build": {
    "appId": "com.clipsync.app",
    "productName": "ClipSync",
    "electronDist": "node_modules/electron/dist",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "package.json"
    ],
    "asar": false,
    "win": {
      "icon": "src/web/assets/icon-512.png",
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "ClipSync",
      "uninstallDisplayName": "ClipSync"
    }
  }
}
